# Public site URL used for Open Graph, sitemap, and canonical links
NEXT_PUBLIC_SITE_URL=https://lightincorporation.com

# Form delivery: "store" (default, Zustand) | "resend" (POST /api/submit)
NEXT_PUBLIC_FORM_PROVIDER=store

# Resend (use when NEXT_PUBLIC_FORM_PROVIDER=resend)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="LiGHT Incorporation <noreply@yourdomain.com>"
